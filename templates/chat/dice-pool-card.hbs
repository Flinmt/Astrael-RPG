<section class="astrael-chat-card astrael-dice-pool-card" data-actor-id="{{actorId}}" data-use-criticals="{{useCriticals}}" data-is-rouse-check="{{isRouseCheck}}">
  <header class="astrael-chat-header">
    <span class="astrael-chat-kicker">{{kicker}}</span>
    <h2>{{title}}</h2>
    <p>{{actorName}}</p>
  </header>

  <div class="astrael-chat-result" aria-label="Resultado da rolagem">
    <span>Sucessos</span>
    <strong>{{successes}}</strong>
  </div>

  <details class="astrael-chat-dice-footer">
    <summary class="astrael-chat-dice-label">Clique para Mostrar Dados Rolados</summary>
    <div class="astrael-chat-dice" aria-label="Dados rolados">
    {{#each dice as |die|}}
      <span class="astrael-chat-die {{die.type}}" title="{{die.label}}">
        {{die.value}}
      </span>
    {{/each}}
    </div>
  </details>

  {{#unless isRouseCheck}}
  <footer class="astrael-chat-actions">
    <button type="button" class="astrael-reroll-btn" data-action="reroll">
      <i class="fas fa-redo"></i> Rerrolar
    </button>
  </footer>
  {{/unless}}

  {{#if rerolled}}
  <div class="astrael-reroll-badge">Rerolado</div>
  {{/if}}
</section>

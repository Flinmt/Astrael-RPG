<form class="{{cssClass}} astrael-rpg sheet actor" autocomplete="off">
  <main class="sheet-shell">
    <section class="sheet-frame">
      <header class="sheet-header">
        <div class="identity-grid">
          <label class="field-card field-name">
            <span>Nome</span>
            <input name="name" type="text" value="{{actor.name}}" placeholder="Nome do personagem">
          </label>

          <div class="portrait-cell" aria-label="Retrato do personagem">
            <button class="portrait-ring" type="button" data-action="editImage" title="Alterar retrato">
              <img class="profile-img" src="{{actor.img}}" alt="{{actor.name}}">
            </button>
            <div class="xp-compact-card">
              <span class="xp-main-label">Experiência</span>
              <div class="xp-grid">
                <div class="xp-slot" title="XP Gasta">
                  <span class="xp-label">Gasta</span>
                  <input name="system.xp.spent" type="number" value="{{system.xp.spent}}" placeholder="0">
                </div>
                <div class="xp-divider"></div>
                <div class="xp-slot" title="XP Atual">
                  <span class="xp-label">Atual</span>
                  <input name="system.xp.current" type="number" value="{{system.xp.current}}" placeholder="0" readonly>
                </div>
                <div class="xp-divider"></div>
                <div class="xp-slot" title="XP Total">
                  <span class="xp-label">Total</span>
                  <input name="system.xp.total" type="number" value="{{system.xp.total}}" placeholder="0" readonly>
                </div>
              </div>
            </div>
          </div>

          <div class="resource-row health-row">
            <section class="resource-card health-card" data-resource="health">
              <div class="resource-title">
                <span>Vida</span>
                <strong>{{system.resources.health.active}}</strong>
              </div>
              <div class="box-track" aria-label="Marcadores de Vida">
                {{#each system.resources.health.boxes as |box|}}
                  <button class="resource-box {{box.state}}" type="button" data-resource="health" data-index="{{box.index}}" data-state="{{box.state}}" title="Clique para alterar"></button>
                {{/each}}
              </div>
            </section>
            <div class="damage-controls" aria-label="Controles de dano de Vida">
              <button class="damage-card superficial-damage" type="button" data-damage="superficial" data-resource="health" title="Dano superficial">/</button>
              <button class="damage-card aggravated-damage" type="button" data-damage="aggravated" data-resource="health" title="Dano agravado">X</button>
            </div>
          </div>

          <label class="field-card">
            <span>Ambicao</span>
            <input name="system.details.ambition" type="text" value="{{system.details.ambition}}" placeholder="Objetivo amplo do personagem">
          </label>

          <div class="resource-row will-row">
            <section class="resource-card will-card" data-resource="willpower">
              <div class="resource-title">
                <span>Vontade</span>
                <strong>{{system.resources.willpower.active}}</strong>
              </div>
              <div class="box-track" aria-label="Marcadores de Vontade">
                {{#each system.resources.willpower.boxes as |box|}}
                  <button class="resource-box {{box.state}}" type="button" data-resource="willpower" data-index="{{box.index}}" data-state="{{box.state}}" title="Clique para alterar"></button>
                {{/each}}
              </div>
            </section>
            <div class="damage-controls" aria-label="Controles de dano de Vontade">
              <button class="damage-card superficial-damage" type="button" data-damage="superficial" data-resource="willpower" title="Dano superficial">/</button>
              <button class="damage-card aggravated-damage" type="button" data-damage="aggravated" data-resource="willpower" title="Dano agravado">X</button>
            </div>
          </div>

          <label class="field-card">
            <span>Desejo</span>
            <input name="system.details.desire" type="text" value="{{system.details.desire}}" placeholder="Objetivo imediato do personagem">
          </label>

          <button class="rouse-check-card" type="button" data-action="rouseCheck" title="Rolar Teste de Queima">
            <span class="rouse-die" aria-hidden="true">
              <img class="rouse-die-icon" src="systems/astrael-rpg/assets/icons/d10.svg" alt="">
            </span>
            <span class="rouse-label">Teste de Queima</span>
          </button>
        </div>
      </header>

      <nav class="sheet-tabs" aria-label="Abas da ficha">
        <button class="tab-button active" data-tab="attributes" type="button">{{localize "ASTRAEL.Tab.Attributes"}}</button>
        <button class="tab-button" data-tab="advantages" type="button">{{localize "ASTRAEL.Tab.Advantages"}}</button>
        <button class="tab-button" data-tab="hemomancy" type="button">{{localize "ASTRAEL.Tab.Hemomancy"}}</button>
        <button class="tab-button" data-tab="stranger-mark" type="button">{{localize "ASTRAEL.Tab.StrangerMark"}}</button>
        <button class="tab-button" data-tab="convictions" type="button">{{localize "ASTRAEL.Tab.Convictions"}}</button>
        <button class="tab-button" data-tab="settings" type="button">{{localize "ASTRAEL.Tab.Settings"}}</button>
      </nav>

      <section class="sheet-body">
        <div class="tab-panel active" data-tab="attributes">
          <section class="section-card">
            <div class="section-title">
              <h2>{{localize "ASTRAEL.Tab.Attributes"}}</h2>
            </div>
            <div class="three-columns">
              <article class="trait-group physical">
                <h3>{{localize "ASTRAEL.Attributes.Physical"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="strength">{{localize "ASTRAEL.Attribute.Strength"}}</span>
                  <div class="dot-track dots-{{system.attributes.strength.value}}" 
                       data-name="system.attributes.strength.value" 
                       data-value="{{system.attributes.strength.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="dexterity">{{localize "ASTRAEL.Attribute.Dexterity"}}</span>
                  <div class="dot-track dots-{{system.attributes.dexterity.value}}" 
                       data-name="system.attributes.dexterity.value" 
                       data-value="{{system.attributes.dexterity.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="stamina">{{localize "ASTRAEL.Attribute.Stamina"}}</span>
                  <div class="dot-track dots-{{system.attributes.stamina.value}}" 
                       data-name="system.attributes.stamina.value" 
                       data-value="{{system.attributes.stamina.value}}"></div>
                </div>
              </article>

              <article class="trait-group social">
                <h3>{{localize "ASTRAEL.Attributes.Social"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="charisma">{{localize "ASTRAEL.Attribute.Charisma"}}</span>
                  <div class="dot-track dots-{{system.attributes.charisma.value}}" 
                       data-name="system.attributes.charisma.value" 
                       data-value="{{system.attributes.charisma.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="manipulation">{{localize "ASTRAEL.Attribute.Manipulation"}}</span>
                  <div class="dot-track dots-{{system.attributes.manipulation.value}}" 
                       data-name="system.attributes.manipulation.value" 
                       data-value="{{system.attributes.manipulation.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="composure">{{localize "ASTRAEL.Attribute.Composure"}}</span>
                  <div class="dot-track dots-{{system.attributes.composure.value}}" 
                       data-name="system.attributes.composure.value" 
                       data-value="{{system.attributes.composure.value}}"></div>
                </div>
              </article>

              <article class="trait-group mental">
                <h3>{{localize "ASTRAEL.Attributes.Mental"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="intelligence">{{localize "ASTRAEL.Attribute.Intelligence"}}</span>
                  <div class="dot-track dots-{{system.attributes.intelligence.value}}" 
                       data-name="system.attributes.intelligence.value" 
                       data-value="{{system.attributes.intelligence.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="wits">{{localize "ASTRAEL.Attribute.Wits"}}</span>
                  <div class="dot-track dots-{{system.attributes.wits.value}}" 
                       data-name="system.attributes.wits.value" 
                       data-value="{{system.attributes.wits.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="resolve">{{localize "ASTRAEL.Attribute.Resolve"}}</span>
                  <div class="dot-track dots-{{system.attributes.resolve.value}}" 
                       data-name="system.attributes.resolve.value" 
                       data-value="{{system.attributes.resolve.value}}"></div>
                </div>
              </article>
            </div>
          </section>
          
          <section class="section-card skills-card">
            <div class="section-title">
              <h2>{{localize "ASTRAEL.Skills.Title"}}</h2>
            </div>
            <div class="three-columns skill-columns">
              <article class="trait-group physical">
                <h3>{{localize "ASTRAEL.Skills.Physical"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="athletics">{{localize "ASTRAEL.Skill.Athletics"}}</span>
                  <div class="dot-track dots-{{system.skills.athletics.value}}" 
                       data-name="system.skills.athletics.value" 
                       data-value="{{system.skills.athletics.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="brawl">{{localize "ASTRAEL.Skill.Brawl"}}</span>
                  <div class="dot-track dots-{{system.skills.brawl.value}}" 
                       data-name="system.skills.brawl.value" 
                       data-value="{{system.skills.brawl.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="drive">{{localize "ASTRAEL.Skill.Drive"}}</span>
                  <div class="dot-track dots-{{system.skills.drive.value}}" 
                       data-name="system.skills.drive.value" 
                       data-value="{{system.skills.drive.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="stealth">{{localize "ASTRAEL.Skill.Stealth"}}</span>
                  <div class="dot-track dots-{{system.skills.stealth.value}}" 
                       data-name="system.skills.stealth.value" 
                       data-value="{{system.skills.stealth.value}}"></div>
                </div>

                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="larceny">{{localize "ASTRAEL.Skill.Larceny"}}</span>
                  <div class="dot-track dots-{{system.skills.larceny.value}}" 
                       data-name="system.skills.larceny.value" 
                       data-value="{{system.skills.larceny.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="crafts">{{localize "ASTRAEL.Skill.Crafts"}}</span>
                  <div class="dot-track dots-{{system.skills.crafts.value}}" 
                       data-name="system.skills.crafts.value" 
                       data-value="{{system.skills.crafts.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="firearms">{{localize "ASTRAEL.Skill.Firearms"}}</span>
                  <div class="dot-track dots-{{system.skills.firearms.value}}" 
                       data-name="system.skills.firearms.value" 
                       data-value="{{system.skills.firearms.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="melee">{{localize "ASTRAEL.Skill.Melee"}}</span>
                  <div class="dot-track dots-{{system.skills.melee.value}}" 
                       data-name="system.skills.melee.value" 
                       data-value="{{system.skills.melee.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="survival">{{localize "ASTRAEL.Skill.Survival"}}</span>
                  <div class="dot-track dots-{{system.skills.survival.value}}" 
                       data-name="system.skills.survival.value" 
                       data-value="{{system.skills.survival.value}}"></div>
                </div>
              </article>

              <article class="trait-group social">
                <h3>{{localize "ASTRAEL.Skills.Social"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="animalKen">{{localize "ASTRAEL.Skill.AnimalKen"}}</span>
                  <div class="dot-track dots-{{system.skills.animalKen.value}}" 
                       data-name="system.skills.animalKen.value" 
                       data-value="{{system.skills.animalKen.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="empathy">{{localize "ASTRAEL.Skill.Empathy"}}</span>
                  <div class="dot-track dots-{{system.skills.empathy.value}}" 
                       data-name="system.skills.empathy.value" 
                       data-value="{{system.skills.empathy.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="etiquette">{{localize "ASTRAEL.Skill.Etiquette"}}</span>
                  <div class="dot-track dots-{{system.skills.etiquette.value}}" 
                       data-name="system.skills.etiquette.value" 
                       data-value="{{system.skills.etiquette.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="expression">{{localize "ASTRAEL.Skill.Expression"}}</span>
                  <div class="dot-track dots-{{system.skills.expression.value}}" 
                       data-name="system.skills.expression.value" 
                       data-value="{{system.skills.expression.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="intimidation">{{localize "ASTRAEL.Skill.Intimidation"}}</span>
                  <div class="dot-track dots-{{system.skills.intimidation.value}}" 
                       data-name="system.skills.intimidation.value" 
                       data-value="{{system.skills.intimidation.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="leadership">{{localize "ASTRAEL.Skill.Leadership"}}</span>
                  <div class="dot-track dots-{{system.skills.leadership.value}}" 
                       data-name="system.skills.leadership.value" 
                       data-value="{{system.skills.leadership.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="persuasion">{{localize "ASTRAEL.Skill.Persuasion"}}</span>
                  <div class="dot-track dots-{{system.skills.persuasion.value}}" 
                       data-name="system.skills.persuasion.value" 
                       data-value="{{system.skills.persuasion.value}}"></div>
                </div>

                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="streetwise">{{localize "ASTRAEL.Skill.Streetwise"}}</span>
                  <div class="dot-track dots-{{system.skills.streetwise.value}}" 
                       data-name="system.skills.streetwise.value" 
                       data-value="{{system.skills.streetwise.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="subterfuge">{{localize "ASTRAEL.Skill.Subterfuge"}}</span>
                  <div class="dot-track dots-{{system.skills.subterfuge.value}}" 
                       data-name="system.skills.subterfuge.value" 
                       data-value="{{system.skills.subterfuge.value}}"></div>
                </div>
              </article>

              <article class="trait-group mental">
                <h3>{{localize "ASTRAEL.Skills.Mental"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="academics">{{localize "ASTRAEL.Skill.Academics"}}</span>
                  <div class="dot-track dots-{{system.skills.academics.value}}" 
                       data-name="system.skills.academics.value" 
                       data-value="{{system.skills.academics.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="awareness">{{localize "ASTRAEL.Skill.Awareness"}}</span>
                  <div class="dot-track dots-{{system.skills.awareness.value}}" 
                       data-name="system.skills.awareness.value" 
                       data-value="{{system.skills.awareness.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="finance">{{localize "ASTRAEL.Skill.Finance"}}</span>
                  <div class="dot-track dots-{{system.skills.finance.value}}" 
                       data-name="system.skills.finance.value" 
                       data-value="{{system.skills.finance.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="investigation">{{localize "ASTRAEL.Skill.Investigation"}}</span>
                  <div class="dot-track dots-{{system.skills.investigation.value}}" 
                       data-name="system.skills.investigation.value" 
                       data-value="{{system.skills.investigation.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="medicine">{{localize "ASTRAEL.Skill.Medicine"}}</span>
                  <div class="dot-track dots-{{system.skills.medicine.value}}" 
                       data-name="system.skills.medicine.value" 
                       data-value="{{system.skills.medicine.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="occult">{{localize "ASTRAEL.Skill.Occult"}}</span>
                  <div class="dot-track dots-{{system.skills.occult.value}}" 
                       data-name="system.skills.occult.value" 
                       data-value="{{system.skills.occult.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="politics">{{localize "ASTRAEL.Skill.Politics"}}</span>
                  <div class="dot-track dots-{{system.skills.politics.value}}" 
                       data-name="system.skills.politics.value" 
                       data-value="{{system.skills.politics.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="science">{{localize "ASTRAEL.Skill.Science"}}</span>
                  <div class="dot-track dots-{{system.skills.science.value}}" 
                       data-name="system.skills.science.value" 
                       data-value="{{system.skills.science.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="technology">{{localize "ASTRAEL.Skill.Technology"}}</span>
                  <div class="dot-track dots-{{system.skills.technology.value}}" 
                       data-name="system.skills.technology.value" 
                       data-value="{{system.skills.technology.value}}"></div>
                </div>
              </article>
            </div>
          </section>

          <details class="section-card specialty-card">
            <summary class="section-title">
              <h2>Especialidades</h2>
              <span>Clique para Expandir ou Recolher</span>
            </summary>
            <div class="specialty-grid">
              {{#each system.specialties as |spec|}}
              <div class="specialty-entry" data-index="{{@index}}" data-action="edit-specialty">
                <span class="specialty-skill">{{spec.skillLabel}}</span>
                <span class="specialty-desc">{{spec.description}}</span>
              </div>
              {{/each}}
              <button type="button" class="specialty-add" data-action="add-specialty">+</button>
            </div>
          </details>

          <details class="section-card custom-roll-card">
            <summary class="section-title">
              <h2>Rolagens Personalizadas</h2>
              <span>Clique para Expandir ou Recolher</span>
            </summary>
            <div class="custom-roll-grid">
              {{#each system.customRolls as |roll|}}
              <div class="custom-roll-entry" data-index="{{@index}}">
                <span class="custom-roll-name">{{roll.name}}</span>
                <button type="button" class="custom-roll-gear" data-action="edit-custom-roll" data-index="{{@index}}"><i class="fas fa-cog"></i></button>
              </div>
              {{/each}}
              <button type="button" class="custom-roll-add" data-action="add-custom-roll">+</button>
            </div>
          </details>
        </div>
        <div class="tab-panel" data-tab="advantages">
          <div class="panel-heading">
            <div>
              <span class="eyebrow">Recursos e complicações</span>
              <h1>Vantagens e Desvantagens</h1>
            </div>
            <p>Campos editáveis para registro de Antecedentes, Vantagens e Defeitos do personagem.</p>
          </div>

          <div class="two-columns">
            <section class="section-card ledger-card advantage-ledger">
              <div class="section-title">
                <h2>Vantagens</h2>
                <span>7 pontos na criação</span>
              </div>
              <div class="ledger-list">
                {{#each system.advantages as |adv|}}
                <div class="ledger-entry">
                  <label><span>Nome</span><input type="text" name="system.advantages.{{@index}}.name" value="{{adv.name}}"></label>
                  <label><span>Pontos</span><input type="text" name="system.advantages.{{@index}}.points" value="{{adv.points}}"></label>
                  <label class="wide"><span>Detalhes</span><input type="text" name="system.advantages.{{@index}}.details" value="{{adv.details}}"></label>
                  <button type="button" class="specialty-remove" data-action="remove-advantage" data-index="{{@index}}">✕</button>
                </div>
                {{/each}}
              </div>
              <button class="ghost-button" type="button" data-action="add-advantage">Adicionar vantagem</button>
            </section>

            <section class="section-card ledger-card flaw-ledger">
              <div class="section-title">
                <h2>Desvantagens</h2>
                <span>2 pontos na criação</span>
              </div>
              <div class="ledger-list">
                {{#each system.flaws as |flaw|}}
                <div class="ledger-entry">
                  <label><span>Nome</span><input type="text" name="system.flaws.{{@index}}.name" value="{{flaw.name}}"></label>
                  <label><span>Pontos</span><input type="text" name="system.flaws.{{@index}}.points" value="{{flaw.points}}"></label>
                  <label class="wide"><span>Detalhes</span><input type="text" name="system.flaws.{{@index}}.details" value="{{flaw.details}}"></label>
                  <button type="button" class="specialty-remove" data-action="remove-flaw" data-index="{{@index}}">✕</button>
                </div>
                {{/each}}
              </div>
              <button class="ghost-button danger" type="button" data-action="add-flaw">Adicionar desvantagem</button>
            </section>
          </div>
        </div>
        <div class="tab-panel" data-tab="hemomancy"></div>
        <div class="tab-panel" data-tab="stranger-mark"></div>
        <div class="tab-panel" data-tab="convictions"></div>
        <div class="tab-panel" data-tab="settings"></div>
      </section>
    </section>
  </main>
</form>

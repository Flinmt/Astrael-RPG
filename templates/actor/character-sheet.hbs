<form class="{{cssClass}} astrael-rpg sheet actor" autocomplete="off">
  <main class="sheet-shell">
    <section class="sheet-frame">
      <header class="sheet-header">
        <div class="identity-grid">
          <label class="field-card field-name">
            <span>Nome</span>
            <input name="name" type="text" value="{{actor.name}}" placeholder="Nome do personagem">
          </label>

          <div class="portrait-cell" aria-label="Retrato do personagem">
            <button class="portrait-ring" type="button" data-action="editImage" title="Alterar retrato">
              <img class="profile-img" src="{{actor.img}}" alt="{{actor.name}}">
            </button>
            <div class="xp-compact-card">
              <span class="xp-main-label">Experiência</span>
              <div class="xp-grid">
                <div class="xp-slot" title="XP Gasta">
                  <span class="xp-label">Gasta</span>
                  <input name="system.xp.spent" type="number" value="{{system.xp.spent}}" placeholder="0">
                </div>
                <div class="xp-divider"></div>
                <div class="xp-slot" title="XP Atual">
                  <span class="xp-label">Atual</span>
                  <input name="system.xp.current" type="number" value="{{system.xp.current}}" placeholder="0" readonly>
                </div>
                <div class="xp-divider"></div>
                <div class="xp-slot" title="XP Total">
                  <span class="xp-label">Total</span>
                  <input name="system.xp.total" type="number" value="{{system.xp.total}}" placeholder="0" readonly>
                </div>
              </div>
            </div>
          </div>

          <div class="resource-row health-row">
            <section class="resource-card health-card" data-resource="health">
              <div class="resource-title">
                <span>{{localize "ASTRAEL.Resource.Health"}}</span>
                <strong class="resource-active-roman">{{system.resources.health.activeRoman}}</strong>
              </div>
              <div class="box-track" aria-label="{{localize 'ASTRAEL.Resource.Health'}}">
                {{#each system.resources.health.boxes as |box|}}
                  <button class="resource-box {{box.state}}" type="button" data-resource="health" data-index="{{box.index}}" data-state="{{box.state}}" title="Clique para alterar"></button>
                {{/each}}
              </div>
            </section>
            <div class="damage-controls" aria-label="{{localize 'ASTRAEL.Resource.Health'}}">
              <button class="damage-card superficial-damage" type="button" data-damage="superficial" data-resource="health" title="Dano superficial">/</button>
              <button class="damage-card aggravated-damage" type="button" data-damage="aggravated" data-resource="health" title="Dano agravado">X</button>
            </div>
          </div>

          <label class="field-card">
            <span>Ambicao</span>
            <input name="system.details.ambition" type="text" value="{{system.details.ambition}}" placeholder="Objetivo amplo do personagem">
          </label>

          <div class="resource-row will-row">
            <section class="resource-card will-card" data-resource="willpower">
              <div class="resource-title">
                <span>{{localize "ASTRAEL.Resource.Willpower"}}</span>
                <strong class="resource-active-roman">{{system.resources.willpower.activeRoman}}</strong>
              </div>
              <div class="box-track" aria-label="{{localize 'ASTRAEL.Resource.Willpower'}}">
                {{#each system.resources.willpower.boxes as |box|}}
                  <button class="resource-box {{box.state}}" type="button" data-resource="willpower" data-index="{{box.index}}" data-state="{{box.state}}" title="Clique para alterar"></button>
                {{/each}}
              </div>
            </section>
            <div class="damage-controls" aria-label="{{localize 'ASTRAEL.Resource.Willpower'}}">
              <button class="damage-card superficial-damage" type="button" data-damage="superficial" data-resource="willpower" title="Dano superficial">/</button>
              <button class="damage-card aggravated-damage" type="button" data-damage="aggravated" data-resource="willpower" title="Dano agravado">X</button>
            </div>
          </div>

          <label class="field-card">
            <span>Desejo</span>
            <input name="system.details.desire" type="text" value="{{system.details.desire}}" placeholder="Objetivo imediato do personagem">
          </label>

          <div class="sangria-vazio-block">
            <section class="marker-card marker-card--sangria">
              <div class="marker-title">
                <span>{{localize "ASTRAEL.Sangria"}}</span>
                <div class="marker-controls">
                  <button type="button" class="marker-btn" data-action="adjust-resource" data-resource="sangria" data-delta="-1">−</button>
                  <button type="button" class="marker-btn" data-action="adjust-resource" data-resource="sangria" data-delta="1">+</button>
                </div>
              </div>
              <div class="dot-track dot-track--sangria dots-{{system.sangria.value}}" data-name="system.sangria.value" data-value="{{system.sangria.value}}">
                <span class="sv-track-label">{{system.sangria.value}}/5</span>
              </div>
            </section>
            <section class="marker-card marker-card--vazio">
              <div class="marker-title">
                <span>{{localize "ASTRAEL.Vazio"}}</span>
                <div class="marker-controls">
                  <button type="button" class="marker-btn" data-action="adjust-resource" data-resource="vazio" data-delta="-1">−</button>
                  <button type="button" class="marker-btn" data-action="adjust-resource" data-resource="vazio" data-delta="1">+</button>
                </div>
              </div>
              <div class="dot-track dot-track--vazio dots-{{system.vazio.value}}" data-name="system.vazio.value" data-value="{{system.vazio.value}}">
                <span class="sv-track-label">{{system.vazio.value}}/5</span>
              </div>
            </section>
          </div>

        </div>
      </header>

      <nav class="sheet-tabs" aria-label="Abas da ficha">
        <button class="tab-button active" data-tab="attributes" type="button">{{localize "ASTRAEL.Tab.Attributes"}}</button>
        <button class="tab-button" data-tab="advantages" type="button">{{localize "ASTRAEL.Tab.Advantages"}}</button>
        <button class="tab-button" data-tab="convictions" type="button">{{localize "ASTRAEL.Tab.Convictions"}}</button>
        <button class="tab-button" data-tab="hemomancy" type="button">{{localize "ASTRAEL.Tab.Hemomancy"}}</button>
        <button class="tab-button" data-tab="stranger-mark" type="button">{{localize "ASTRAEL.Tab.StrangerMark"}}</button>
        <button class="settings-gear" data-tab="settings" type="button" title="{{localize 'ASTRAEL.Tab.Settings'}}">
          <i class="fas fa-cog"></i>
        </button>
      </nav>

      <section class="sheet-body">
        <div class="tab-panel active" data-tab="attributes">
          <section class="section-card">
            <div class="section-title">
              <h2>{{localize "ASTRAEL.Tab.Attributes"}}</h2>
            </div>
            <div class="three-columns">
              <article class="trait-group physical">
                <h3>{{localize "ASTRAEL.Attributes.Physical"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="strength">{{localize "ASTRAEL.Attribute.Strength"}}</span>
                  <div class="dot-track dots-{{system.attributes.strength.value}}" 
                       data-name="system.attributes.strength.value" 
                       data-value="{{system.attributes.strength.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="dexterity">{{localize "ASTRAEL.Attribute.Dexterity"}}</span>
                  <div class="dot-track dots-{{system.attributes.dexterity.value}}" 
                       data-name="system.attributes.dexterity.value" 
                       data-value="{{system.attributes.dexterity.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="stamina">{{localize "ASTRAEL.Attribute.Stamina"}}</span>
                  <div class="dot-track dots-{{system.attributes.stamina.value}}" 
                       data-name="system.attributes.stamina.value" 
                       data-value="{{system.attributes.stamina.value}}"></div>
                </div>
              </article>

              <article class="trait-group social">
                <h3>{{localize "ASTRAEL.Attributes.Social"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="charisma">{{localize "ASTRAEL.Attribute.Charisma"}}</span>
                  <div class="dot-track dots-{{system.attributes.charisma.value}}" 
                       data-name="system.attributes.charisma.value" 
                       data-value="{{system.attributes.charisma.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="manipulation">{{localize "ASTRAEL.Attribute.Manipulation"}}</span>
                  <div class="dot-track dots-{{system.attributes.manipulation.value}}" 
                       data-name="system.attributes.manipulation.value" 
                       data-value="{{system.attributes.manipulation.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="composure">{{localize "ASTRAEL.Attribute.Composure"}}</span>
                  <div class="dot-track dots-{{system.attributes.composure.value}}" 
                       data-name="system.attributes.composure.value" 
                       data-value="{{system.attributes.composure.value}}"></div>
                </div>
              </article>

              <article class="trait-group mental">
                <h3>{{localize "ASTRAEL.Attributes.Mental"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="intelligence">{{localize "ASTRAEL.Attribute.Intelligence"}}</span>
                  <div class="dot-track dots-{{system.attributes.intelligence.value}}" 
                       data-name="system.attributes.intelligence.value" 
                       data-value="{{system.attributes.intelligence.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="wits">{{localize "ASTRAEL.Attribute.Wits"}}</span>
                  <div class="dot-track dots-{{system.attributes.wits.value}}" 
                       data-name="system.attributes.wits.value" 
                       data-value="{{system.attributes.wits.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="attribute" data-key="resolve">{{localize "ASTRAEL.Attribute.Resolve"}}</span>
                  <div class="dot-track dots-{{system.attributes.resolve.value}}" 
                       data-name="system.attributes.resolve.value" 
                       data-value="{{system.attributes.resolve.value}}"></div>
                </div>
              </article>
            </div>
          </section>
          
          <section class="section-card skills-card">
            <div class="section-title">
              <h2>{{localize "ASTRAEL.Skills.Title"}}</h2>
              <button type="button" class="specialty-open" data-action="open-specialties" title="Especialidades" aria-label="Especialidades">
                <span class="specialty-open-icon" aria-hidden="true"></span>
              </button>
            </div>
            <div class="three-columns skill-columns">
              <article class="trait-group physical">
                <h3>{{localize "ASTRAEL.Skills.Physical"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="athletics">{{localize "ASTRAEL.Skill.Athletics"}}</span>
                  <div class="dot-track dots-{{system.skills.athletics.value}}" 
                       data-name="system.skills.athletics.value" 

                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="firearms">{{localize "ASTRAEL.Skill.Firearms"}}</span>
                  <div class="dot-track dots-{{system.skills.firearms.value}}" 
                       data-name="system.skills.firearms.value" 

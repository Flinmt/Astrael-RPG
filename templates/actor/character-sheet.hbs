                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="stealth">{{localize "ASTRAEL.Skill.Stealth"}}</span>
                  <div class="dot-track dots-{{system.skills.stealth.value}}" 
                       data-name="system.skills.stealth.value" 
                       data-value="{{system.skills.stealth.value}}"></div>
                </div>

                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="larceny">{{localize "ASTRAEL.Skill.Larceny"}}</span>
                  <div class="dot-track dots-{{system.skills.larceny.value}}" 
                       data-name="system.skills.larceny.value" 
                       data-value="{{system.skills.larceny.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="crafts">{{localize "ASTRAEL.Skill.Crafts"}}</span>
                  <div class="dot-track dots-{{system.skills.crafts.value}}" 
                       data-name="system.skills.crafts.value" 

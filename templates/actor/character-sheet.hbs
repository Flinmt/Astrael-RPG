                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="melee">{{localize "ASTRAEL.Skill.Melee"}}</span>
                  <div class="dot-track dots-{{system.skills.melee.value}}" 
                       data-name="system.skills.melee.value" 
                       data-value="{{system.skills.melee.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="survival">{{localize "ASTRAEL.Skill.Survival"}}</span>
                  <div class="dot-track dots-{{system.skills.survival.value}}" 
                       data-name="system.skills.survival.value" 
                       data-value="{{system.skills.survival.value}}"></div>
                </div>
              </article>

              <article class="trait-group social">
                <h3>{{localize "ASTRAEL.Skills.Social"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="animalKen">{{localize "ASTRAEL.Skill.AnimalKen"}}</span>
                  <div class="dot-track dots-{{system.skills.animalKen.value}}" 
                       data-name="system.skills.animalKen.value" 
                       data-value="{{system.skills.animalKen.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="empathy">{{localize "ASTRAEL.Skill.Empathy"}}</span>
                  <div class="dot-track dots-{{system.skills.empathy.value}}" 
                       data-name="system.skills.empathy.value" 
                       data-value="{{system.skills.empathy.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="etiquette">{{localize "ASTRAEL.Skill.Etiquette"}}</span>
                  <div class="dot-track dots-{{system.skills.etiquette.value}}" 
                       data-name="system.skills.etiquette.value" 
                       data-value="{{system.skills.etiquette.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="expression">{{localize "ASTRAEL.Skill.Expression"}}</span>
                  <div class="dot-track dots-{{system.skills.expression.value}}" 
                       data-name="system.skills.expression.value" 
                       data-value="{{system.skills.expression.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="intimidation">{{localize "ASTRAEL.Skill.Intimidation"}}</span>
                  <div class="dot-track dots-{{system.skills.intimidation.value}}" 
                       data-name="system.skills.intimidation.value" 
                       data-value="{{system.skills.intimidation.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="leadership">{{localize "ASTRAEL.Skill.Leadership"}}</span>
                  <div class="dot-track dots-{{system.skills.leadership.value}}" 
                       data-name="system.skills.leadership.value" 
                       data-value="{{system.skills.leadership.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="persuasion">{{localize "ASTRAEL.Skill.Persuasion"}}</span>
                  <div class="dot-track dots-{{system.skills.persuasion.value}}" 
                       data-name="system.skills.persuasion.value" 
                       data-value="{{system.skills.persuasion.value}}"></div>
                </div>

                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="streetwise">{{localize "ASTRAEL.Skill.Streetwise"}}</span>
                  <div class="dot-track dots-{{system.skills.streetwise.value}}" 
                       data-name="system.skills.streetwise.value" 
                       data-value="{{system.skills.streetwise.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="subterfuge">{{localize "ASTRAEL.Skill.Subterfuge"}}</span>
                  <div class="dot-track dots-{{system.skills.subterfuge.value}}" 
                       data-name="system.skills.subterfuge.value" 
                       data-value="{{system.skills.subterfuge.value}}"></div>
                </div>
              </article>

              <article class="trait-group mental">
                <h3>{{localize "ASTRAEL.Skills.Mental"}}</h3>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="academics">{{localize "ASTRAEL.Skill.Academics"}}</span>
                  <div class="dot-track dots-{{system.skills.academics.value}}" 
                       data-name="system.skills.academics.value" 
                       data-value="{{system.skills.academics.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="awareness">{{localize "ASTRAEL.Skill.Awareness"}}</span>
                  <div class="dot-track dots-{{system.skills.awareness.value}}" 
                       data-name="system.skills.awareness.value" 
                       data-value="{{system.skills.awareness.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="finance">{{localize "ASTRAEL.Skill.Finance"}}</span>
                  <div class="dot-track dots-{{system.skills.finance.value}}" 
                       data-name="system.skills.finance.value" 
                       data-value="{{system.skills.finance.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="investigation">{{localize "ASTRAEL.Skill.Investigation"}}</span>
                  <div class="dot-track dots-{{system.skills.investigation.value}}" 
                       data-name="system.skills.investigation.value" 
                       data-value="{{system.skills.investigation.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="medicine">{{localize "ASTRAEL.Skill.Medicine"}}</span>
                  <div class="dot-track dots-{{system.skills.medicine.value}}" 
                       data-name="system.skills.medicine.value" 
                       data-value="{{system.skills.medicine.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="occult">{{localize "ASTRAEL.Skill.Occult"}}</span>
                  <div class="dot-track dots-{{system.skills.occult.value}}" 
                       data-name="system.skills.occult.value" 
                       data-value="{{system.skills.occult.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="politics">{{localize "ASTRAEL.Skill.Politics"}}</span>
                  <div class="dot-track dots-{{system.skills.politics.value}}" 
                       data-name="system.skills.politics.value" 
                       data-value="{{system.skills.politics.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="science">{{localize "ASTRAEL.Skill.Science"}}</span>
                  <div class="dot-track dots-{{system.skills.science.value}}" 
                       data-name="system.skills.science.value" 
                       data-value="{{system.skills.science.value}}"></div>
                </div>
                
                <div class="trait-row">
                  <span class="rollable" data-type="skill" data-key="technology">{{localize "ASTRAEL.Skill.Technology"}}</span>
                  <div class="dot-track dots-{{system.skills.technology.value}}" 
                       data-name="system.skills.technology.value" 
                       data-value="{{system.skills.technology.value}}"></div>
                </div>
              </article>
            </div>
          </section>

          <details class="section-card custom-roll-card">
            <summary class="section-title">
              <h2>Rolagens Personalizadas</h2>
              <span>Clique para Expandir ou Recolher</span>
            </summary>
            <div class="custom-roll-grid">
              {{#each system.customRolls as |roll|}}
              <div class="custom-roll-entry" data-index="{{@index}}">
                <span class="custom-roll-name">{{roll.name}}</span>
                <button type="button" class="custom-roll-gear" data-action="edit-custom-roll" data-index="{{@index}}"><i class="fas fa-cog"></i></button>
              </div>
              {{/each}}
              <button type="button" class="custom-roll-add" data-action="add-custom-roll">+</button>
            </div>
          </details>
        </div>
        <div class="tab-panel" data-tab="advantages">
          <div class="advantage-browser">
            <aside class="advantage-sidebar" data-mode="{{#if system.advantageModeFlaws}}flaws{{else}}advantages{{/if}}">
              <header class="advantage-browser-header">
                <div class="advantage-browser-header-row">
                  <div>
                    <span>{{#if system.advantageModeFlaws}}Arquivos Comprometedores{{else}}Dossie Favoravel{{/if}}</span>
                    <h2>Caracteristicas</h2>
                  </div>
                  <button type="button" class="advantage-add" data-action="add-advantage-entry" title="{{#if system.advantageModeFlaws}}Adicionar desvantagem{{else}}Adicionar vantagem{{/if}}">+</button>
                </div>
              </header>

              <div class="advantage-mode-tabs">
                <button type="button" class="advantage-mode-tab {{#unless system.advantageModeFlaws}}active{{/unless}}" data-action="set-advantage-mode" data-mode="advantages">Vantagens</button>
                <button type="button" class="advantage-mode-tab {{#if system.advantageModeFlaws}}active{{/if}}" data-action="set-advantage-mode" data-mode="flaws">Desvantagens</button>
              </div>

              <div class="advantage-list-container">
                <div class="advantage-list {{#if system.advantageModeFlaws}}is-hidden{{/if}}" data-list="advantages">
                  {{#each system.advantages as |adv|}}
                  <button type="button" class="advantage-row {{#if adv.selected}}is-selected{{/if}}" data-action="select-advantage-entry" data-list="advantages" data-index="{{@index}}">
                    <span class="advantage-row-rank" aria-label="Nivel {{adv.level}}">{{adv.levelRoman}}</span>
                    <span class="advantage-row-name">{{adv.name}}</span>
                  </button>
                  {{/each}}
                </div>
                <div class="advantage-list {{#unless system.advantageModeFlaws}}is-hidden{{/unless}}" data-list="flaws">
                  {{#each system.flaws as |flaw|}}
                  <button type="button" class="advantage-row flaw-row {{#if flaw.selected}}is-selected{{/if}}" data-action="select-advantage-entry" data-list="flaws" data-index="{{@index}}">
                    <span class="advantage-row-rank flaw-rank" aria-label="Nivel {{flaw.level}}">{{flaw.levelRoman}}</span>
                    <span class="advantage-row-name">{{flaw.name}}</span>
                  </button>
                  {{/each}}
                </div>
              </div>
            </aside>

            <section class="advantage-inspector {{#if system.advantageModeFlaws}}flaw-inspector{{/if}}">
              {{#if system.selectedAdvantage}}
              {{#if system.selectedAdvantage.editing}}
              <div class="advantage-inspector-edit-header">
                <span class="advantage-inspector-kicker">{{system.selectedAdvantage.typeLabel}}</span>
                <button type="button" class="advantage-rank {{#if system.selectedAdvantage.isFlaw}}flaw-rank{{/if}}" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}" aria-label="Nivel {{system.selectedAdvantage.level}}">{{system.selectedAdvantage.levelRoman}}</button>
              </div>
              <div class="advantage-inspector-form">
                <label>
                  <span>Nome</span>
                  <input class="advantage-name-input" type="text" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}" value="{{system.selectedAdvantage.name}}" placeholder="Nome da {{system.selectedAdvantage.actionLabel}}">
                </label>
                <label>
                  <span>Descricao</span>
                  <textarea class="advantage-description-input" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}" placeholder="Descreva o efeito, contexto ou detalhe narrativo.">{{system.selectedAdvantage.description}}</textarea>
                </label>
              </div>
              {{else}}
              <div class="advantage-inspector-kicker">{{system.selectedAdvantage.typeLabel}}</div>
              <div class="advantage-inspector-title-row">
                <h2>{{system.selectedAdvantage.name}}</h2>
                <button type="button" class="advantage-rank {{#if system.selectedAdvantage.isFlaw}}flaw-rank{{/if}}" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}" aria-label="Nivel {{system.selectedAdvantage.level}}">{{system.selectedAdvantage.levelRoman}}</button>
              </div>
              <div class="advantage-inspector-copy">
                <p>{{#if system.selectedAdvantage.description}}{{system.selectedAdvantage.description}}{{else}}Sem descricao registrada.{{/if}}</p>
              </div>
              {{/if}}

              <div class="advantage-inspector-actions">
                {{#unless system.selectedAdvantage.editing}}
                {{#unless system.selectedAdvantage.isFlaw}}
                <button type="button" class="advantage-command advantage-roll" data-action="roll-advantage-entry" data-index="{{system.selectedAdvantage.index}}">Rolar</button>
                {{/unless}}
                {{/unless}}
                {{#if system.selectedAdvantage.editing}}
                <button type="button" class="advantage-command" data-action="save-advantage-entry" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}">Salvar</button>
                {{else}}
                <button type="button" class="advantage-command" data-action="edit-advantage-entry" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}">Editar</button>
                {{/if}}
                <button type="button" class="advantage-command danger" data-action="delete-advantage-entry" data-list="{{system.selectedAdvantage.listId}}" data-index="{{system.selectedAdvantage.index}}">Excluir</button>
              </div>
              {{else}}
              <div class="advantage-empty-inspector">
                <span>Nenhum registro selecionado</span>
                <p>Crie uma vantagem ou desvantagem para abrir um dossie.</p>
              </div>
              {{/if}}
            </section>
          </div>
        </div>
        <div class="tab-panel" data-tab="hemomancy">
          <div class="hemomancy-browser">
            <aside class="hemomancy-sidebar">
              <header class="hemomancy-browser-header">
                <div class="hemomancy-browser-header-row">
                  <div>
                    <span>Sangue Invocado</span>
                    <h2>Magias</h2>
                  </div>
                </div>
              </header>

              <div class="hemomancy-mode-tabs">
                {{#each system.hemomancy.modeTabs as |tab|}}
                <button type="button" class="hemomancy-mode-tab {{#if tab.active}}active{{/if}}" data-action="set-hemomancy-mode" data-level="{{tab.level}}">{{tab.roman}}</button>
                {{/each}}
              </div>

              <div class="hemomancy-list-container">
                <div class="hemomancy-list">
                  {{#each system.hemomancy.powers as |power|}}
                  {{#unless power.hidden}}
                  <button type="button" class="hemomancy-row {{#if power.selected}}is-selected{{/if}}" data-action="select-hemomancy-power" data-index="{{@index}}">
                    <span class="hemomancy-row-name">{{power.name}}</span>
                  </button>
                  {{/unless}}
                  {{/each}}
                  <button type="button" class="hemomancy-add" data-action="add-hemomancy-power" title="Adicionar magia" {{#if (eq system.hemomancy.level 0)}}disabled{{/if}}>+</button>
                </div>
              </div>
            </aside>

            <section class="hemomancy-inspector">
              <div class="hemomancy-level-card">
                <div>
                  <span>Potencia da Hemomencia</span>
                </div>
                <button type="button" class="hemomancy-level-control" title="Clique para aumentar, botao direito para reduzir">{{system.hemomancy.levelRoman}}</button>
              </div>
              <div class="hemomancy-detail-content">

              {{#if system.hemomancy.selectedPower}}
              {{#if system.hemomancy.selectedPower.editing}}
              <div class="hemomancy-inspector-edit-header">
                <span class="hemomancy-inspector-kicker">Sangue Invocado</span>
              </div>
              <div class="hemomancy-inspector-form">
                <label>
                  <span>Nome</span>
                  <input class="hemomancy-name-input" type="text" data-index="{{system.hemomancy.selectedPower.index}}" value="{{system.hemomancy.selectedPower.name}}" placeholder="Nome da magia">
                </label>
                <label>
                  <span>Custo</span>
                  <input class="hemomancy-cost-input" type="number" min="1" max="5" data-index="{{system.hemomancy.selectedPower.index}}" value="{{system.hemomancy.selectedPower.cost}}">
                </label>
                <label class="hemomancy-description-field">
                  <span>Descricao</span>
                  <textarea class="hemomancy-description-input" data-index="{{system.hemomancy.selectedPower.index}}" placeholder="Descreva efeito, alcance e consequencias da magia.">{{system.hemomancy.selectedPower.description}}</textarea>
                </label>
              </div>
              {{else}}
              <div class="hemomancy-inspector-kicker">Sangue Invocado</div>
              <div class="hemomancy-inspector-title-row">
                <h2>{{system.hemomancy.selectedPower.name}}</h2>
              </div>
              <div class="hemomancy-meta-row">
                <div class="hemomancy-cost" title="Custo de Queima">
                  {{#each system.hemomancy.selectedPower.costIcons as |icon|}}
                  <img src="systems/astrael-rpg/assets/icons/d10.svg" alt="" class="hemomancy-cost-icon">
                  {{/each}}
                </div>
                <span>{{system.hemomancy.selectedPower.rollFormula}}</span>
              </div>
              <div class="hemomancy-inspector-copy">
                <p>{{#if system.hemomancy.selectedPower.description}}{{system.hemomancy.selectedPower.description}}{{else}}Sem descricao registrada.{{/if}}</p>
              </div>
              {{/if}}

              <div class="hemomancy-inspector-actions">
                {{#unless system.hemomancy.selectedPower.editing}}
                <button type="button" class="hemomancy-command hemomancy-roll" data-action="roll-hemomancy-power" data-index="{{system.hemomancy.selectedPower.index}}">Rolar</button>
                {{/unless}}
                {{#if system.hemomancy.selectedPower.editing}}
                <button type="button" class="hemomancy-command" data-action="save-hemomancy-power" data-index="{{system.hemomancy.selectedPower.index}}">Salvar</button>
                {{else}}
                <button type="button" class="hemomancy-command" data-action="edit-hemomancy-power" data-index="{{system.hemomancy.selectedPower.index}}">Editar</button>
                {{/if}}
                <button type="button" class="hemomancy-command danger" data-action="delete-hemomancy-power" data-index="{{system.hemomancy.selectedPower.index}}">Excluir</button>
              </div>
              {{else}}
              <div class="hemomancy-empty-inspector">
                <span>Nenhuma magia selecionada</span>
                <p>Crie uma magia no circulo {{system.hemomancy.modeRoman}} para abrir o grimorio de sangue.</p>
              </div>
              {{/if}}
              </div>
            </section>
          </div>
        </div>
        <div class="tab-panel" data-tab="stranger-mark">
          {{#if system.strangerMark.selectedMark}}
          <div class="stranger-mark-browser">
            <aside class="stranger-mark-sidebar">
              <header class="stranger-mark-browser-header">
                <div class="stranger-mark-browser-header-row">
                  <div class="stranger-mark-title-row">
                    <button type="button" class="stranger-mark-panel-toggle" data-action="toggle-stranger-marks-panel" title="Abrir painel de marcas">☰</button>
                    <div class="stranger-mark-title-text">
                      <span>Marca ativa</span>
                      <h2>{{system.strangerMark.selectedMark.label}}</h2>
                    </div>
                  </div>
                </div>
              </header>

              <div class="stranger-mark-mode-tabs">
                {{#each system.strangerMark.abilityLevelTabs as |tab|}}
                <button type="button" class="stranger-mark-mode-tab {{#if tab.active}}active{{/if}}" data-action="set-stranger-mark-ability-level" data-level="{{tab.level}}">{{tab.roman}}</button>
                {{/each}}
              </div>

              <div class="stranger-mark-list-container">
                <div class="stranger-mark-list">
                  {{#each system.strangerMark.visibleAbilities as |ability|}}
                  <button type="button" class="stranger-mark-row {{#if ability.selected}}is-selected{{/if}}" data-action="select-stranger-mark-ability" data-index="{{ability.index}}">
                    <span class="stranger-mark-row-name">{{ability.name}}</span>
                  </button>
                  {{/each}}
                  <button type="button" class="stranger-mark-add" data-action="add-stranger-mark-ability" title="Adicionar habilidade" {{#if (eq system.strangerMark.selectedMark.level 0)}}disabled{{/if}}>+</button>
                </div>
              </div>
            </aside>

            <section class="stranger-mark-inspector">
              <div class="stranger-mark-level-card">
                <div>
                  <span>Potencia da marca</span>
                  <strong>{{system.strangerMark.selectedMark.label}}</strong>
                </div>
                <button type="button" class="stranger-mark-level-control" data-option="{{system.strangerMark.selectedMark.option}}" title="Clique para aumentar, botao direito para reduzir">{{system.strangerMark.selectedMark.levelRoman}}</button>
              </div>
              <div class="stranger-mark-detail-content">

              {{#if system.strangerMark.selectedAbility}}
              {{#if system.strangerMark.selectedAbility.editing}}
              <div class="stranger-mark-inspector-edit-header">
                <span class="stranger-mark-inspector-kicker">Marca do Estranho</span>
              </div>
              <div class="stranger-mark-inspector-form">
                <label>
                  <span>Nome</span>
                  <input class="stranger-mark-name-input" type="text" data-index="{{system.strangerMark.selectedAbility.index}}" value="{{system.strangerMark.selectedAbility.name}}" placeholder="Nome da habilidade">
                </label>
                <label>
                  <span>Custo</span>
                  <input class="stranger-mark-cost-input" type="number" min="1" max="5" data-index="{{system.strangerMark.selectedAbility.index}}" value="{{system.strangerMark.selectedAbility.cost}}">
                </label>
                <label class="stranger-mark-description-field">
                  <span>Descricao</span>
                  <textarea class="stranger-mark-description-input" data-index="{{system.strangerMark.selectedAbility.index}}" placeholder="Descreva o efeito da habilidade.">{{system.strangerMark.selectedAbility.description}}</textarea>
                </label>
              </div>
              {{else}}
              <div class="stranger-mark-inspector-kicker">Marca do Estranho</div>
              <div class="stranger-mark-inspector-title-row">
                <h2>{{system.strangerMark.selectedAbility.name}}</h2>
              </div>
              <div class="stranger-mark-meta-row">
                <div class="stranger-mark-cost" title="Custo de Queima">
                  {{#each system.strangerMark.selectedAbility.costIcons as |icon|}}
                  <img src="systems/astrael-rpg/assets/icons/d10.svg" alt="" class="stranger-mark-cost-icon">
                  {{/each}}
                </div>
                <span>{{system.strangerMark.selectedAbility.rollFormula}}</span>
              </div>
              <div class="stranger-mark-inspector-copy">
                <p>{{#if system.strangerMark.selectedAbility.description}}{{system.strangerMark.selectedAbility.description}}{{else}}Sem descricao registrada.{{/if}}</p>
              </div>
              {{/if}}

              <div class="stranger-mark-inspector-actions">
                {{#unless system.strangerMark.selectedAbility.editing}}
                <button type="button" class="stranger-mark-command stranger-mark-roll" data-action="roll-stranger-mark-ability" data-index="{{system.strangerMark.selectedAbility.index}}">Rolar</button>
                {{/unless}}
                {{#if system.strangerMark.selectedAbility.editing}}
                <button type="button" class="stranger-mark-command" data-action="save-stranger-mark-ability" data-index="{{system.strangerMark.selectedAbility.index}}">Salvar</button>
                {{else}}
                <button type="button" class="stranger-mark-command" data-action="edit-stranger-mark-ability" data-index="{{system.strangerMark.selectedAbility.index}}">Editar</button>
                {{/if}}
                <button type="button" class="stranger-mark-command danger" data-action="delete-stranger-mark-ability" data-index="{{system.strangerMark.selectedAbility.index}}">Excluir</button>
              </div>
              {{else}}
              <div class="stranger-mark-empty-inspector">
                <span>Nenhuma habilidade selecionada</span>
                <p>Crie uma habilidade no circulo {{system.strangerMark.selectedAbilityLevelRoman}} desta marca.</p>
              </div>
              {{/if}}
              </div>
            </section>
          </div>
          {{else}}
          <div class="stranger-mark-no-mark">
            <span>Nenhuma marca selecionada</span>
            <button type="button" data-action="toggle-stranger-marks-panel">Abrir painel de marcas</button>
          </div>
          {{/if}}
        </div>
        <div class="tab-panel" data-tab="convictions">
          <section class="convictions-panel">
            <div class="conviction-grid">
              {{#each system.convictions as |conviction|}}
              <div class="conviction-column">
                <header class="convictions-fracture-header">
                  <div class="fracture-title">
                    <span>{{localize "ASTRAEL.Convictions.FracturesHint"}}</span>
                    <h2>{{localize "ASTRAEL.Convictions.Fractures"}}</h2>
                  </div>
                  <div class="fracture-track" aria-label="{{localize 'ASTRAEL.Convictions.Fractures'}}">
                    {{#each conviction.fractureBoxes as |box|}}
                    <button class="fracture-box {{#if box.filled}}filled{{/if}}" type="button" data-conviction-index="{{conviction.index}}" data-index="{{box.index}}" title="{{localize 'ASTRAEL.Convictions.Fractures'}}"></button>
                    {{/each}}
                  </div>
                </header>
              <article class="conviction-card {{#if conviction.editing}}is-editing{{/if}}" data-index="{{conviction.index}}">
                {{#if conviction.editing}}
                <header class="conviction-card-title">
                  <label class="conviction-edit-field">
                    <span>{{localize "ASTRAEL.Convictions.Name"}}</span>
                    <input class="conviction-name-input" type="text" data-index="{{conviction.index}}" value="{{conviction.name}}" placeholder="{{localize 'ASTRAEL.Convictions.NamePlaceholder'}}">
                  </label>
                </header>

                <label class="conviction-edit-field">
                  <span>{{localize "ASTRAEL.Convictions.Description"}}</span>
                  <textarea class="conviction-description-input" data-index="{{conviction.index}}" placeholder="{{localize 'ASTRAEL.Convictions.DescriptionPlaceholder'}}">{{conviction.description}}</textarea>
                </label>

                <div class="conviction-pillar-head">
                  <span>{{localize "ASTRAEL.Convictions.Pillar"}}</span>
                </div>

                <div class="conviction-pillar-list">
                  <div class="conviction-pillar-row" data-conviction-index="{{conviction.index}}">
                    <input class="pillar-name-input" type="text" data-conviction-index="{{conviction.index}}" value="{{conviction.pillar.name}}" placeholder="{{localize 'ASTRAEL.Convictions.PillarName'}}">
                    {{#if conviction.isCenter}}
                    <input class="pillar-type-input" type="hidden" data-conviction-index="{{conviction.index}}" value="Pessoa">
                    <div class="pillar-type-locked">{{localize "ASTRAEL.Convictions.PillarTypePessoa"}}</div>
                    {{else}}
                    <select class="pillar-type-input" data-conviction-index="{{conviction.index}}">
                      {{#each conviction.pillarTypeOptions as |option|}}
                      <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                      {{/each}}
                    </select>
                    {{/if}}
                  </div>
                </div>

                <footer class="conviction-card-actions">
                  <button type="button" class="conviction-command" data-action="save-conviction" data-index="{{conviction.index}}">{{localize "ASTRAEL.Convictions.Save"}}</button>
                </footer>
                {{else}}
                <header class="conviction-card-title">
                  <h3>{{#if conviction.name}}{{conviction.name}}{{else}}{{localize "ASTRAEL.Convictions.EmptyName"}}{{/if}}</h3>
                  <button type="button" class="conviction-icon-button" data-action="edit-conviction" data-index="{{conviction.index}}" title="{{localize 'ASTRAEL.Convictions.Edit'}}">
                    <i class="fas fa-pen"></i>
                  </button>
                </header>

                <div class="conviction-description">
                  <p>{{#if conviction.description}}{{conviction.description}}{{else}}{{localize "ASTRAEL.Convictions.EmptyDescription"}}{{/if}}</p>
                </div>

                <div class="conviction-pillar-head">
                  <span>{{localize "ASTRAEL.Convictions.Pillar"}}</span>
                </div>

                <div class="conviction-pillar-list">
                  <div class="conviction-pillar-card">
                    <strong>{{#if conviction.pillar.name}}{{conviction.pillar.name}}{{else}}{{localize "ASTRAEL.Convictions.EmptyPillarName"}}{{/if}}</strong>
                    <span>{{conviction.pillar.type}}</span>
                  </div>
                </div>
                {{/if}}
              </article>
              </div>
              {{/each}}
            </div>
          </section>
        </div>
        <div class="tab-panel" data-tab="settings"></div>
      </section>
    </section>
  </main>
</form>
